<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.18362.0</TargetFramework>
    <RootNamespace>PattonsBest</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Description>Solo game replicating 4th armor path during WW2</Description>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnableNETAnalyzers>True</EnableNETAnalyzers>
    <UseWindowsForms>True</UseWindowsForms>
    <StartupObject>PattonsBest.App</StartupObject>
    <Title>Pattons Best Solo Game</Title>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <AssemblyName>PattonsBest</AssemblyName>
    <Company>$(Authors)</Company>
    <Authors>$(AssemblyName)</Authors>
    <SupportedOSPlatformVersion>10.0.18362.0</SupportedOSPlatformVersion>
    <RepositoryUrl>https://github.com/happysulla/PattonsBest</RepositoryUrl>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <ApplicationIcon>PattonsBest.ico</ApplicationIcon>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <AssemblyVersion>1.0.3.41</AssemblyVersion>
    <FileVersion></FileVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <Optimize>True</Optimize>
  </PropertyGroup>

